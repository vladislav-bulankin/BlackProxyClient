<Page x:Class="BlackTunnel.UI.Views.ServersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BlackTunnel.UI.Views"
      xmlns:vm="clr-namespace:BlackTunnel.UI.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Servers"
      Background="#0F0F0F"
      DataContext="ServersViewModel">

    <Page.Resources>
        <!-- Только стиль большой кнопки CONNECT -->
        <Style x:Key="ConnectButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="999"
                                Width="260"
                                Height="260">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34C49E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0F9C6B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Верхняя панель -->
        <Border Background="#1A1A1A" Height="70" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0">
                <TextBlock Text="MyVPN" 
                           FontSize="22" 
                           FontWeight="SemiBold" 
                           Foreground="White"/>

                <TextBlock Text="{Binding ConnectionStatus}" 
                           Margin="20,0,0,0"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Foreground="{Binding StatusColor}"/>
            </StackPanel>
        </Border>

        <!-- Большая кнопка CONNECT -->
        <Button Style="{StaticResource ConnectButtonStyle}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,-40,0,0"
                Command="{Binding ConnectCommand}">

            <StackPanel>
                <TextBlock Text="CONNECT" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentServerName}" 
                           FontSize="16" 
                           Foreground="#E5E7EB"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Button>

        <!-- Статус подключения -->
        <TextBlock Text="{Binding ConnectionStatus}" 
                   FontSize="18"
                   FontWeight="Medium"
                   HorizontalAlignment="Center"
                   Margin="0,170,0,0"
                   Foreground="{Binding StatusColor}"/>

        <!-- Список серверов -->
        <ListView Margin="20,380,20,30"
                  Background="Transparent"
                  BorderThickness="0"
                  ItemsSource="{Binding Servers}"
                  SelectedItem="{Binding SelectedServer}">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1F1F1F" 
                            CornerRadius="8" 
                            Margin="0,6"
                            Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Flag}" FontSize="26" Grid.Column="0" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" 
                                           FontSize="16" 
                                           FontWeight="Medium" 
                                           Foreground="White"/>
                                <TextBlock Text="{Binding City}" 
                                           FontSize="13" 
                                           Foreground="#9CA3AF"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Ping, StringFormat={}{0} ms}" 
                                       Grid.Column="2"
                                       FontSize="14"
                                       Foreground="#10B981"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
