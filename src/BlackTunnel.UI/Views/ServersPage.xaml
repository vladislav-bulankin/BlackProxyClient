<Page x:Class="BlackTunnel.UI.Views.ServersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Servers"
      Background="#0E1117">

    <Page.Resources>

        <!-- Thin scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#2E3340" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Power button style -->
        <Style x:Key="PowerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Bg" Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.3"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Server list row style: removes default blue highlight -->
        <Style x:Key="ServerItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#181C25">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#161A23"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#1C2133"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ping color: green when low, yellow when mid, red when high -->
        <Style x:Key="PingTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#10B981"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 1. Шапка: логотип + кнопка питания -->
            <RowDefinition Height="64"/>
            <!-- 2. Строка статуса подключения -->
            <RowDefinition Height="48"/>
            <!-- 3. Заголовок секции "ВСЕ СЕРВЕРЫ" -->
            <RowDefinition Height="38"/>
            <!-- 4. Список серверов (растягивается) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════
             ROW 0 — Шапка
             ══════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#13161F"
                BorderThickness="0,0,0,1"
                BorderBrush="#1E2130">
            <Grid Margin="18,0">

                <!-- Логотип -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <!-- Иконка-щит -->
                    <Viewbox Width="22" Height="22" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 2 L20 5.5 V11 C20 16 16.4 20.4 12 22 C7.6 20.4 4 16 4 11 V5.5 Z"
                                  Fill="#4A9EFF"/>
                            <Path Data="M9 12 L11 14 L15 10"
                                  Stroke="White"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="BlackTunnel"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Кнопка подключения -->
                <Button Grid.Column="0"
                        Style="{StaticResource PowerButtonStyle}"
                        HorizontalAlignment="Right"
                        Background="{Binding ButtonColor}"
                        Command="{Binding ConnectCommand}"
                        ToolTip="{Binding ButtonText}">
                    <!-- Иконка «power» нарисована через Path -->
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 3 V12"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                            <Path Data="M7.5 6.5 A7.5 7.5 0 1 0 16.5 6.5"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  Fill="Transparent"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>

            </Grid>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 1 — Статус подключения
             ══════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#0E1117"
                BorderThickness="0,0,0,1"
                BorderBrush="#181C25"
                Padding="18,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Цветная точка статуса -->
                <Ellipse Width="8" Height="8"
                         Fill="{Binding StatusColor}"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0">
                    <Ellipse.Effect>
                        <BlurEffect Radius="4"/>
                    </Ellipse.Effect>
                </Ellipse>

                <TextBlock Text="{Binding ConnectionStatus}"
                           FontSize="13"
                           Foreground="#9CA3AF"
                           VerticalAlignment="Center"/>

                <!-- Разделитель -->
                <TextBlock Text=" · "
                           FontSize="13"
                           Foreground="#374151"
                           VerticalAlignment="Center"/>

                <!-- Название сервера -->
                <TextBlock Text="{Binding CurrentServerName}"
                           FontSize="13"
                           Foreground="White"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="220"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 2 — Заголовок секции
             ══════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#0A0D13"
                Padding="18,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="ALL SERVERS"
                           FontSize="10.5"
                           FontWeight="SemiBold"
                           Foreground="#4B5563"
                           VerticalAlignment="Center"
                           Typography.Capitals="AllSmallCaps"/>
                <Border Background="#1E2130"
                        CornerRadius="4"
                        Padding="6,2"
                        Margin="8,0,0,0">
                    <TextBlock Text="{Binding Servers.Count}"
                               FontSize="10.5"
                               Foreground="#6B7280"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════
             ROW 3 — Список серверов
             ══════════════════════════════════════ -->
        <ListView Grid.Row="3"
                  Background="#0E1117"
                  BorderThickness="0"
                  ItemsSource="{Binding Servers}"
                  SelectedItem="{Binding SelectedServer}"
                  ItemContainerStyle="{StaticResource ServerItemStyle}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="18,11">
                        <Grid.ColumnDefinitions>
                            <!-- Флаг -->
                            <ColumnDefinition Width="34"/>
                            <!-- Имя + город -->
                            <ColumnDefinition Width="*"/>
                            <!-- Пинг -->
                            <ColumnDefinition Width="54"/>
                            <!-- Иконка ">" -->
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>

                        <!-- Флаг эмодзи -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Flag}"
                                   FontSize="22"
                                   VerticalAlignment="Center"/>

                        <!-- Название и город -->
                        <StackPanel Grid.Column="1"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Foreground="#E5E7EB"/>
                            <TextBlock Text="{Binding City}"
                                       FontSize="11.5"
                                       Foreground="#4B5563"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Пинг с цветом -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Ping, StringFormat={}{0} ms}"
                                   Style="{StaticResource PingTextStyle}"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,8,0"/>

                        <!-- Шеврон -->
                        <TextBlock Grid.Column="3"
                                   Text="›"
                                   FontSize="18"
                                   Foreground="#374151"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
