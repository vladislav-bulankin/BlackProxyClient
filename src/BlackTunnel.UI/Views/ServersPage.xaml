<Page x:Class="BlackTunnel.UI.Views.ServersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:BlackTunnel.UI"
      Title="Servers"
      Background="#0E1117">

    <Page.Resources>

        <!-- Scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#2E3340" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Power button -->
        <Style x:Key="PowerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Bg" Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.3"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- List item -->
        <Style x:Key="ServerItemStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder"
                                Background="Transparent"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#181C25">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#161A23"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#1C2133"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ping -->
        <Style x:Key="PingTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#10B981"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="48"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#13161F"
                BorderThickness="0,0,0,1"
                BorderBrush="#1E2130">
            <Grid Margin="18,0">

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Viewbox Width="22" Height="22" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 2 L20 5.5 V11 C20 16 16.4 20.4 12 22 C7.6 20.4 4 16 4 11 V5.5 Z"
                                  Fill="#4A9EFF"/>
                            <Path Data="M9 12 L11 14 L15 10"
                                  Stroke="White"
                                  StrokeThickness="1.5"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="BlackTunnel"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

                <Button Style="{StaticResource PowerButtonStyle}"
                        HorizontalAlignment="Right"
                        Background="{Binding ButtonColor}"
                        Command="{Binding ConnectCommand}"/>
            </Grid>
        </Border>

        <!-- STATUS -->
        <Border Grid.Row="1"
                Background="#0E1117"
                BorderThickness="0,0,0,1"
                BorderBrush="#181C25"
                Padding="18,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Ellipse Width="8" Height="8"
                         Fill="{Binding StatusColor}"
                         Margin="0,0,10,0"/>

                <TextBlock Text="{Binding ConnectionStatus}"
                           Foreground="#9CA3AF"/>

                <TextBlock Text=" · "
                           Foreground="#374151"/>

                <TextBlock Text="{Binding CurrentServerName}"
                           Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- TITLE -->
        <Border Grid.Row="2"
                Background="#0A0D13"
                Padding="18,0">
            <TextBlock Text="ALL SERVERS"
                       Foreground="#4B5563"/>
        </Border>

        <!-- LIST + OVERLAY -->
        <Grid Grid.Row="3">

            <ListView Background="#0E1117"
                      BorderThickness="0"
                      ItemsSource="{Binding Servers}"
                      SelectedItem="{Binding SelectedServer}"
                      ItemContainerStyle="{StaticResource ServerItemStyle}">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="18,11">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="54"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Flag}"
                                       FontSize="22"/>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding Name}" Foreground="#E5E7EB"/>
                                <TextBlock Text="{Binding City}" Foreground="#4B5563"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Ping, StringFormat={}{0} ms}"
                                       Style="{StaticResource PingTextStyle}"/>

                            <TextBlock Grid.Column="3"
                                       Text="›"
                                       Foreground="#374151"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- ERROR OVERLAY -->
            <Grid Background="#880E1117"
                  IsHitTestVisible="False"
                  Visibility="{Binding ConnectionState, Converter={StaticResource ErrorVisibility}}">

                <Border Background="#1A1F2B"
                        CornerRadius="12"
                        Padding="20"
                        Width="300"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="True">

                    <StackPanel>

                        <TextBlock Text="⚠"
                                   FontSize="26"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Connection failed"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,6"/>

                        <TextBlock Text="{Binding ConnectionError}"
                                   Foreground="#9CA3AF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>

    </Grid>
</Page>