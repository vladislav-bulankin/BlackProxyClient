<Page x:Class="BlackTunnel.UI.Views.ServersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BlackTunnel.UI.Views"
      xmlns:vm="clr-namespace:BlackTunnel.UI.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Servers"
      Background="#0F0F0F"
      DataContext="ServersViewModel">

    <Page.Resources>
        <!-- Тень для кнопки (должна быть первой) -->
        <DropShadowEffect x:Key="DropShadow" 
                          Color="#000000" 
                          Direction="270" 
                          ShadowDepth="8" 
                          BlurRadius="25" 
                          Opacity="0.55"/>

        <!-- Стиль большой кнопки Connect / Disconnect -->
        <Style x:Key="ConnectButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="260"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="999"
                                Effect="{StaticResource DropShadow}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Изменение цвета при наведении и нажатии -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{Binding ButtonHoverColor, RelativeSource={RelativeSource AncestorType=Page}, FallbackValue=#34C49E}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{Binding ButtonPressedColor, RelativeSource={RelativeSource AncestorType=Page}, FallbackValue=#0F9C6B}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Верхняя панель -->
        <Border Background="#1A1A1A" Height="70" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0">
                <TextBlock Text="MyVPN" 
                           FontSize="22" 
                           FontWeight="SemiBold" 
                           Foreground="White"/>

                <TextBlock Text="{Binding ConnectionStatus}" 
                           Margin="20,0,0,0"
                           FontSize="15"
                           VerticalAlignment="Center"
                           Foreground="{Binding StatusColor}"/>
            </StackPanel>
        </Border>

        <!-- Большая кнопка -->
        <Button Style="{StaticResource ConnectButtonStyle}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,-30,0,0"
                Background="{Binding ButtonColor}"
                Command="{Binding ConnectCommand}">

            <StackPanel>
                <TextBlock Text="{Binding ButtonText}" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentServerName}" 
                           FontSize="15" 
                           Foreground="#D1D5DB"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Button>

        <!-- Список серверов -->
        <ListView Margin="20,390,20,30"
                  Background="Transparent"
                  BorderThickness="0"
                  ItemsSource="{Binding Servers}"
                  SelectedItem="{Binding SelectedServer}">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1F1F1F" 
                            CornerRadius="10" 
                            Margin="0,6"
                            Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Flag}" 
                                       FontSize="26" 
                                       Grid.Column="0" 
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" 
                                           FontSize="16" 
                                           FontWeight="Medium" 
                                           Foreground="White"/>
                                <TextBlock Text="{Binding City}" 
                                           FontSize="13" 
                                           Foreground="#9CA3AF"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Ping, StringFormat={}{0} ms}" 
                                       Grid.Column="2"
                                       FontSize="14"
                                       Foreground="#10B981"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
