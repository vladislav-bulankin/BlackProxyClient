<Page x:Class="BlackTunnel.UI.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Login"
      Background="#0E1117">

    <Page.Resources>

        <!-- Поле ввода: скруглённое, без системного outline при фокусе -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#13161F"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="CaretBrush" Value="#4A9EFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1E2130"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4A9EFF"/>
                                <Setter TargetName="Root" Property="Background" Value="#161A23"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2E3858"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox аналогично -->
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#13161F"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="CaretBrush" Value="#4A9EFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1E2130"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4A9EFF"/>
                                <Setter TargetName="Root" Property="Background" Value="#161A23"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2E3858"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка Log In: зелёная активная, тёмная неактивная -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0EA472"/>
                            </Trigger>

                            <!-- Нажатие -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#059660"/>
                            </Trigger>

                            <!-- Неактивна: тёмный фон вместо системного белого -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#1C2133"/>
                                <Setter Property="Foreground" Value="#4B5563"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <!-- Центрируем карточку на странице -->
    <Grid VerticalAlignment="Center">

        <Border Background="#13161F"
                CornerRadius="14"
                MaxWidth="340"
                Margin="20">

            <!-- Тонкая светящаяся рамка -->
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E2840" Offset="0"/>
                    <GradientStop Color="#0D1120" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>

            <StackPanel Margin="28,30">

                <!-- Иконка-щит -->
                <Viewbox Width="36" Height="36"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,14">
                    <Canvas Width="24" Height="24">
                        <Path Data="M12 2 L20 5.5 V11 C20 16 16.4 20.4 12 22 C7.6 20.4 4 16 4 11 V5.5 Z"
                              Fill="#4A9EFF"/>
                        <Path Data="M9 12 L11 14 L15 10"
                              Stroke="White"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>
                    </Canvas>
                </Viewbox>

                <!-- Заголовок -->
                <TextBlock Text="Black Proxy"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="White"
                           Margin="0,0,0,6"/>

                <!-- Подзаголовок -->
                <TextBlock Text="Freedom of speech is freedom of thought."
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Foreground="#4B5563"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Username -->
                <TextBlock Text="Username or email"
                           FontSize="12"
                           Foreground="#6B7280"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="txtUsername"
                         Style="{StaticResource InputStyle}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Password -->
                <TextBlock Text="Password"
                           FontSize="12"
                           Foreground="#6B7280"
                           Margin="0,16,0,6"/>
                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource PasswordStyle}"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Кнопка -->
                <Button x:Name="btnLogin"
                        Content="Log In"
                        Style="{StaticResource LoginButtonStyle}"
                        Margin="0,24,0,0"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding CanLogin}"/>

                <!-- Ошибка -->
                <TextBlock Foreground="#EF4444"
                           FontSize="12"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="{Binding ErrorMessage,
                               Converter={StaticResource NullToCollapsedConverter}}"
                           Text="{Binding ErrorMessage}"/>

                <!-- Прогресс -->
                <ProgressBar IsIndeterminate="True"
                             Height="2"
                             Margin="0,12,0,0"
                             Background="Transparent"
                             Foreground="#4A9EFF"
                             BorderThickness="0"
                             Visibility="{Binding IsLoading,
                                 Converter={StaticResource BooleanToVisibilityConverter}}"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
