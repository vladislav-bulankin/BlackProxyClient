<Page x:Class="BlackTunnel.UI.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BlackTunnel.UI.Views"
      mc:Ignorable="d" d:DesignWidth="800"
      Title="Login" Height="502">
    <Grid>
        <Border Background="#1A1A1A" CornerRadius="12" MaxWidth="340" Margin="20">
            <StackPanel Margin="30">

                <TextBlock Text="Black Proxy" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,10"
                           Foreground="White"/>

                <TextBlock Text="Freedom of speech is freedom of thought." 
                   FontSize="12" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,30"
                   Foreground="DarkRed"/>

                <TextBlock Text="Sign in" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"
                           Foreground="White"/>
                
                <TextBlock Text="Username or email" FontSize="14" Margin="0,0,0,6" Foreground="#D1D5DB"/>
                <TextBox x:Name="txtUsername"
                         Height="44"
                         Padding="14,0"
                         FontSize="15"
                         Background="#252525"
                         BorderBrush="#3A3A3A"
                         BorderThickness="1"
                         Foreground="White"
                         CaretBrush="White"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Password" FontSize="14" Margin="0,20,0,6" Foreground="#D1D5DB"/>
                <PasswordBox x:Name="txtPassword"
                             Height="44"
                             Padding="14,0"
                             FontSize="15"
                             Background="#252525"
                             BorderBrush="#3A3A3A"
                             BorderThickness="1"
                             Foreground="White"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <Button x:Name="btnLogin"
                        Content="Log In"
                        Height="48"
                        Margin="0,30,0,0"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#10B981"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding !IsLoading}"/>

                <TextBlock x:Name="txtError"
                           Foreground="#EF4444"
                           FontSize="13"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>
                <!-- Индикатор загрузки -->
                <ProgressBar IsIndeterminate="True" 
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Margin="0,10"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
